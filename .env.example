# Copy to `.env` and fill in. Never commit a real `.env` (it is gitignored).

# --- Acceleration -----------------------------------------------------------------
# Enable RAPIDS cudf.pandas GPU acceleration in the pipeline (requires a CUDA GPU).
USE_GPU=0

# --- Google Cloud (used from P3 onward; all optional via feature flags) ------------
GOOGLE_CLOUD_PROJECT=gen-ai-2-500107
GOOGLE_CLOUD_LOCATION=us-central1
# Authenticate locally with: gcloud auth application-default login  (no key files)

USE_BIGQUERY=0
BIGQUERY_DATASET=gridpulse

USE_GEMINI=0
GEMINI_MODEL=gemini-2.5-flash
